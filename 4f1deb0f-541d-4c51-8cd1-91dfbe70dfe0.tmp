<!DOCTYPE html>
<html lang="he" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>כרטיס ביקור – אופיר אטדגי</title>
<link href="https://fonts.googleapis.com/css2?family=Heebo:wght@200;300;400;500;600;700;800&family=Frank+Ruhl+Libre:wght@300;400;700;900&display=swap" rel="stylesheet">
<style>
* { margin:0; padding:0; box-sizing:border-box; }
:root {
  --navy:    #0e1e35;
  --navy2:   #152845;
  --teal:    #1b6a6e;
  --teal2:   #27979d;
  --gold:    #c49a3c;
  --gold2:   #e3be6a;
  --white:   #ffffff;
  --offwhite:#f5f1ea;
}
body {
  background: #1a1a1a;
  background-image: radial-gradient(ellipse at 30% 30%, #1e2e40 0%, transparent 70%);
  display:flex; flex-direction:column; align-items:center;
  justify-content:center; min-height:100vh; gap:36px;
  font-family:'Heebo',sans-serif; padding:40px 20px;
}
.lbl { font-size:9px; color:#555; letter-spacing:3px; text-transform:uppercase; font-weight:300; }

/* ====== CARD ====== */
.card {
  width:90mm; height:50mm;
  border-radius:3px; overflow:hidden; position:relative;
  box-shadow: 0 8px 40px rgba(0,0,0,0.7), 0 2px 8px rgba(0,0,0,0.5);
  transition: transform .4s cubic-bezier(.25,.8,.25,1), box-shadow .4s;
  cursor: pointer;
}
.card:hover {
  transform: translateY(-6px) rotateX(2deg) scale(1.01);
  box-shadow: 0 30px 70px rgba(0,0,0,0.8), 0 0 0 1px rgba(196,154,60,0.3);
}

/* ====== FRONT ====== */
.front {
  width:100%; height:100%;
  background: var(--navy);
  display:flex; position:relative; overflow:hidden;
}

/* Photo half – left */
.photo-half {
  width: 34mm;
  height: 100%;
  position: relative;
  flex-shrink: 0;
  overflow: hidden;
}
.photo-half img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center top;
  display: block;
  filter: saturate(0.85) contrast(1.05);
}
/* gradient overlay blending photo into navy */
.photo-half::after {
  content:'';
  position:absolute; top:0; left:0; right:0; bottom:0;
  background: linear-gradient(
    to right,
    transparent 55%,
    rgba(14,30,53,0.6) 80%,
    var(--navy) 100%
  ), linear-gradient(
    to bottom,
    rgba(14,30,53,0.1) 0%,
    transparent 20%,
    transparent 75%,
    rgba(14,30,53,0.5) 100%
  );
}
/* gold line on right edge */
.photo-half::before {
  content:'';
  position:absolute; top:10%; bottom:10%; right:0;
  width:1.5px;
  background: linear-gradient(180deg, transparent, var(--gold), transparent);
  z-index:2;
}

/* Text half – right */
.text-half {
  flex:1;
  display:flex;
  flex-direction:column;
  justify-content:space-between;
  padding: 5mm 5.5mm 4.5mm 4.5mm;
  position:relative;
  overflow:hidden;
}

/* top gold bar */
.text-half::before {
  content:'';
  position:absolute; top:0; left:0; right:0;
  height:2px;
  background: linear-gradient(90deg, var(--teal), var(--gold2), transparent);
}

/* subtle circle bg */
.text-half::after {
  content:'';
  position:absolute; bottom:-10mm; right:-8mm;
  width:30mm; height:30mm;
  border-radius:50%;
  border:1px solid rgba(196,154,60,0.07);
  pointer-events:none;
}

/* TH Logo top right */
.th-logo {
  position:absolute;
  top: 4mm; left: 4mm;  /* RTL: left = far right */
  width:10mm; height:10mm;
  object-fit:contain;
  filter:brightness(0) invert(1);
  opacity:0.85;
  z-index:1;
}

.top-block { display:flex; flex-direction:column; gap:1.5px; margin-top:1mm; }

.brand-line {
  font-size:6px; color:var(--teal2);
  letter-spacing:1.5px; font-weight:400;
  text-transform:uppercase;
}

.gold-rule {
  width:100%; height:0.5px;
  background: linear-gradient(90deg, var(--gold) 0%, rgba(196,154,60,0.15) 100%);
  margin: 1.5px 0;
}

.name {
  font-family:'Frank Ruhl Libre',serif;
  font-size:19px; color:var(--white);
  font-weight:900; line-height:1;
  letter-spacing:-0.5px;
}

.title {
  font-size:6.5px; color:var(--teal2);
  font-weight:500; letter-spacing:0.4px; margin-top:1.5px;
}

.exp {
  font-size:6px; color:rgba(255,255,255,0.45);
  font-weight:300; letter-spacing:0.3px; margin-top:1px;
}

.mdrt-tag {
  display:inline-flex; align-items:center; gap:3px;
  margin-top:2.5px;
  background: rgba(196,154,60,0.12);
  border:0.5px solid rgba(196,154,60,0.35);
  border-radius:2px;
  padding: 1.5px 5px;
  width:fit-content;
}
.mdrt-tag span {
  font-size:5.5px; color:var(--gold2);
  font-weight:600; letter-spacing:1.5px;
}

/* contacts */
.contacts { display:flex; flex-direction:column; gap:2.5px; }
.crow { display:flex; align-items:center; gap:3.5px; }
.crow svg { width:8px; height:8px; flex-shrink:0; }
.cval {
  font-size:7px; color:rgba(255,255,255,0.82);
  font-weight:300; letter-spacing:0.3px; direction:ltr;
}

/* ====== BACK ====== */
.back {
  width:100%; height:100%;
  background: rgba(10,18,32,0.72);
  display:flex; flex-direction:column;
  align-items:center; justify-content:center;
  position:relative; overflow:hidden;
  padding:5mm 7mm;
}
.back-photo-bg {
  position:absolute; top:0; left:0; right:0; bottom:0;
  background-image: var(--photo-url);
  background-size: cover;
  background-position: center top;
  filter: saturate(0.75) brightness(0.45) contrast(1.05);
  z-index:0;
}
.back::before {
  content:''; position:absolute; top:0; left:0; right:0;
  height:2px; z-index:2;
  background: linear-gradient(90deg, transparent, var(--teal2), transparent);
}
.back::after {
  content:''; position:absolute; bottom:0; left:0; right:0;
  height:1px; z-index:2;
  background: linear-gradient(90deg, transparent, var(--gold2), transparent);
}
.back-ring1 {
  position:absolute; top:50%; left:50%;
  transform:translate(-50%,-50%);
  width:75mm; height:75mm; border-radius:50%;
  border:0.5px solid rgba(196,154,60,0.1); z-index:1;
}
.back-ring2 {
  position:absolute; top:50%; left:50%;
  transform:translate(-50%,-50%);
  width:48mm; height:48mm; border-radius:50%;
  border:0.5px solid rgba(27,106,110,0.18); z-index:1;
}
.back-content {
  display:flex; flex-direction:column;
  align-items:center; gap:0; z-index:2; position:relative;
}
.back-logo {
  width:13mm; height:13mm;
  object-fit:contain;
  filter:brightness(0) invert(1);
  opacity:0.95;
  margin-bottom:2.5mm;
}
.back-brand {
  font-family:'Frank Ruhl Libre',serif;
  font-size:13px; color:var(--white); text-shadow: 0 1px 6px rgba(0,0,0,0.8);
  font-weight:400; letter-spacing:0.5px;
}
.back-slogan {
  font-size:6.5px; color:var(--teal2);
  letter-spacing:1px; font-weight:300; margin-top:1mm;
}
.back-rule {
  width:16mm; height:0.5px;
  background:linear-gradient(90deg, transparent, var(--gold), transparent);
  margin:3mm 0 2.5mm;
}
.back-svcs {
  display:grid; grid-template-columns:1fr 1fr;
  gap:2.5px 8mm; margin-bottom:3mm;
}
.bsvc {
  font-size:6px; color:rgba(255,255,255,0.5);
  font-weight:300; letter-spacing:0.5px; text-align:center;
}
.back-web {
  font-size:7px; color:var(--gold2);
  letter-spacing:0.5px; font-weight:400; direction:ltr;
}

@media print {
  body { background:white; padding:8mm; gap:12mm; }
  .lbl { display:none; }
  .card { box-shadow:0 0 0 0.5px #ccc; }
  .card:hover { transform:none; }
}
</style>
</head>
<body>

<span class="lbl">פנים</span>
<div class="card" id="frontCard">
  <div class="front">

    <div class="photo-half">
      <img id="ofirPhoto" src="" alt="אופיר אטדגי" />
    </div>

    <img
      class="th-logo"
      src="https://tom-harush.co.il/wp-content/uploads/קבוצת-תום-הרוש-לוגו-ריבועי-ללא-רקע-1-1024x1024.png"
      alt="תום הרוש"
      onerror="this.style.display='none'"
    />

    <div class="text-half">
      <div class="top-block">
        <div class="brand-line">קבוצת תום הרוש</div>
        <div class="gold-rule"></div>
        <div class="name">אופיר אטדגי</div>
        <div class="title">מומחה ביטוח, פיננסים ונדל״ן מסחרי</div>
        <div class="exp">מעל 25 שנות ניסיון</div>
        <div class="mdrt-tag"><span>✦ MDRT MEMBER</span></div>
      </div>

      <div class="contacts">
        <div class="crow">
          <svg viewBox="0 0 24 24" fill="none" stroke="#27979d" stroke-width="2" stroke-linecap="round">
            <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.8 19.79 19.79 0 01.0 1.18 2 2 0 012 0h3a2 2 0 012 1.72c.13.96.36 1.9.7 2.81a2 2 0 01-.45 2.11L6.09 7.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0122 16.92z"/>
          </svg>
          <span class="cval">054-4747944</span>
        </div>
        <div class="crow">
          <svg viewBox="0 0 24 24" fill="none" stroke="#27979d" stroke-width="2" stroke-linecap="round">
            <circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/>
            <path d="M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"/>
          </svg>
          <span class="cval">ofirinsurance.co.il</span>
        </div>
      </div>
    </div>

  </div>
</div>

<span class="lbl">גב</span>
<div class="card">
  <div class="back">
    <div class="back-photo-bg" id="backBg"></div>
    <div class="back-ring1"></div>
    <div class="back-ring2"></div>
    <div class="back-content">
      <img
        class="back-logo"
        src="https://tom-harush.co.il/wp-content/uploads/קבוצת-תום-הרוש-לוגו-ריבועי-ללא-רקע-1-1024x1024.png"
        alt="לוגו"
        onerror="this.style.display='none'"
      />
      <div class="back-brand">קבוצת תום הרוש</div>
      <div class="back-slogan">מבינים אנשים. מומחים בנדל״ן.</div>
      <div class="back-rule"></div>
      <div class="back-svcs">
        <div class="bsvc">ביטוח חיים ובריאות</div>
        <div class="bsvc">פנסיה וחיסכון</div>
        <div class="bsvc">ביטוח רכב ודירה</div>
        <div class="bsvc">נדל״ן מסחרי</div>
        <div class="bsvc">ביטוח עסקים</div>
        <div class="bsvc">משכנתאות</div>
      </div>
      <div class="back-web">tom-harush.co.il</div>
    </div>
  </div>
</div>

<p style="font-size:11px;color:#555;text-align:center;font-family:'Heebo',sans-serif;line-height:1.8">
  Ctrl+P להדפסה | 350 גר׳ + ציפוי מט + UV על הלוגו 🖨️
</p>

<script>
// Embed photo as base64
const b64 = "";
document.getElementById('ofirPhoto').src = 'data:image/jpeg;base64,' + b64;
document.getElementById('backBg').style.backgroundImage = "url('data:image/jpeg;base64,')";
</script>
</body>
</html>
